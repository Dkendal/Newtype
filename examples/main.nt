import "ts-toolbelt"
  ( A
  , B
  , I
  , M
  , Union
  )

import "." ( __ )

import "./const"
  ( __capture__
  , __kind__
  , any_
  , bigint_
  , boolean_
  , function_
  , number_
  , object_
  , rest_
  , string_
  , symbol_
  )

type True = 1

type Primitive = M.Primitive

type BuiltIn = M.BuiltIn

type ExtractSubcapture T =
  if not T <: M.Primitive | M.BuiltIn and T <: object
  then T ! Exclude (keyof T) (keyof []) (keyof {})

type PartialAssignment K V =
  if not V == never and K <: string
  then V for k in K

type EmptyToNever T = if not {} <: T then T

type Kind
  = typeof any_
  | typeof rest_
  | typeof string_
  | typeof number_
  | typeof boolean_
  | typeof function_
  | typeof symbol_
  | typeof bigint_
  | typeof object_

