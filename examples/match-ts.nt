import { A, B, I, M, Union } from 'ts-toolbelt'

// match-ts brands holes and captures with symbol keys (see
// `match-ts/src/const.ts`); as computed keys they must be `unique symbol`s.
unique symbol __kind__
unique symbol __capture__

type True as 1

type ExtractSubcapture(T) as
  match T do
    M::Primitive | M::BuiltIn -> never,
    object -> T[ Exclude(keyof(T), keyof([]) | keyof({})) ],
  end

type PartialAssignment(K, V) as
  cond do
    V <: never -> never,
    K <: string -> map k in K do V end,
    else -> never
  end

type EmptyToNever(T) as
  if {} <: T then
    never
  else
    T
  end

// `Kind` is `typeof any_ | typeof rest_ | …` in match-ts; each `X_` const is a
// string literal (`any_ = 'any'`), so the union is exactly these literals.
export type Kind as
  'any'
  | 'rest'
  | 'string'
  | 'number'
  | 'boolean'
  | 'function'
  | 'symbol'
  | 'bigint'
  | 'object'

export interface Hole(Type, Label)
defaults
  Type = any,
  Label = any
{
  T: Type,
  readonly [__kind__]: Label
}

// The per-type hole singletons and the `__` wildcard map (match-ts `index.ts`).
interface __any extends Hole(any, 'any') {}
export interface __string extends Hole(string, 'string') {}
export interface __number extends Hole(number, 'number') {}
export interface __boolean extends Hole(boolean, 'boolean') {}
export interface __symbol extends Hole(symbol, 'symbol') {}
export interface __bigint extends Hole(bigint, 'bigint') {}
export interface __object extends Hole(Object, 'object') {}
export interface __function extends Hole(Function, 'function') {}
export interface __rest extends Hole(any[], 'rest') {}

export interface __ extends Hole(any, 'any') {
  string: __string,
  number: __number,
  boolean: __boolean,
  // There is something weird going on where including this causes
  // RecursiveCollect to think that it has a circular reference
  object: __object,
  function: __function,
  symbol: __symbol,
  bigint: __bigint,
  any: __any,
  rest: __rest,
  tail: __rest,
  tl: __rest,
}

export type HoleInnerType(T) as
  if T <: Hole(?U) then
    U
  else
    T
  end

export interface Capture(Name, Pattern)
defaults
  Name = any,
  Pattern = any,
where
  Name <: String,
{
  readonly [__capture__]: Name,
  readonly pattern: Pattern,
}

type CapturePattern(T) as
  if T <: Capture(any, ?Pattern) then
    Pattern
  else
    T
  end

type RecursiveExpandCapture(T) as
  if A::Equals(T, any) <: True then
    T
  else
    if T <: Hole | Capture then
      ExpandCapture(T)
    else
      if T <: Record(string, any) then
        map K in keyof(T) do
          ExpandCapture(T[K])
        end
      else
        never
      end
    end
  end

export type ExpandCapture(T) as
  T
  |> HoleInnerType()
  |> CapturePattern()
  |> RecursiveExpandCapture()

type NeverToEmpty(T) as
  if [T] <: [never] then
    {}
  else
    T
  end

type Explode(T) as T[keyof(T)]

export type RecursiveCollect(Node) as
  Node
  |> DoRecursiveCollect()
  |> NeverToEmpty()

type IsLeafNode(T) as
  B::Or(
    B::Not(A::Extends(T, Record(string, any))),
    B::Or(A::Extends(T, Hole), A::Equals(T, any))
  )

type WalkChildren(Node) as
  map Key in keyof(Node) do
    DoRecursiveCollect(Node[Key])
  end
  |> Explode()

type DoRecursiveCollect(Node) as
  if IsLeafNode(Node) <: True then
    never
  else
    if Node <: Capture(any, ?P) then
      Node | DoRecursiveCollect(P)
    else
      WalkChildren(Node)
    end
  end

type UnionizeCapture(T) as
  if T <: Capture(?K, ?V) then
    if K <: string then
      map k in K do
        V
      end
    end
  end

export type CaptureToEntry(T) as
  T
  |> UnionizeCapture()
  |> Union::Merge()

export type VariableCapture(T) as
  T
  |> RecursiveCollect()
  |> CaptureToEntry()
  |> ExpandCapture()

export type PatternHandler(Pattern) as
  (VariableCapture(Pattern)) => unknown

type IsTopType(T) as
  A::Extends(
    True,
    A::Equals(T, unknown)
    | A::Equals(T, object)
    | A::Equals(T, Object)
    | A::Equals(T, any)
  )

export type UnifyAll(Value, Pattern) as
  cond do
    IsTopType(Value) <: True ->
      VariableCapture(Pattern),

    Overlapping(Value, ExpandCapture(Pattern)) <: {} ->
      DoUnifyAll(Value, Pattern)
  end

export type DoUnifyAll(Value, Pattern) as
  cond do
    Pattern <: Capture(?VarName, ?Child) ->
      PartialAssignment(VarName, Overlapping(Value, ExpandCapture(Child)))
      | UnifyAll(Value, Child),

    Overlapping(Value, ExpandCapture(Pattern)) <: object ->
      ExtractSubcapture(
        map K in keyof(Value) do
          if K <: keyof(Pattern) then
            UnifyAll(Value[K], Pattern[K])
          else
            never
          end
        end
      )
  end

export type ShouldUnifyAll(Value, Pattern) as
  B::Not(
    B::Or(
      A::Equals(Pattern, any) & A::Equals(Value, any),
      A::Extends(Pattern, M::Primitive) & A::Extends(Value, M::Primitive)
    )
  )

export type CaseParameters(Value, Pattern) as
  UnifyAll(Value, Pattern)
  |> Union::Merge()
  |> EmptyToNever()

export type Overlapping(A, B, Depth)
defaults
  Depth = I::IterationOf(0)
where
  Depth <: I::Iteration
as
  cond do
    A::Equals(A, any) <: True -> B,
    A <: B -> A,
    [A, B, keyof(A)] <: [any[], any[], any] | [object, object, keyof(B)] ->
      RejectMismatch(
        map Key in keyof(A) do
          if Key <: keyof(B) then
            Overlapping(A[Key], B[Key], I::Next(Depth))
          else
            A[Key]
          end
        end
      )
  end

export type RejectMismatch(T) as
  cond do
    {} <: T -> never,
    T <: AnyNever(A::Cast(T, object)) -> never,
    else -> T
  end

export type AnyNever(T)
where
  T <: object
as
  if keyof(T) <: ?S then
    if S <: any then
      map K in A::Cast(S, string | number | symbol) do
        never
      end
    else
      never
    end
  else
    never
  end
