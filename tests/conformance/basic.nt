// Acceptance fixture: every assertion below must hold in BOTH newtype and tsgo.
// (Subset of examples/test.nt, restricted to claims both systems accept.)

unittest "structural assignability holds" do
  assert string <: unknown
  assert not (number <: string)
  assert () => any <: () => any
  assert () => never <: () => any
  assert () => unknown <: () => any
  assert () => any <: Function
  assert (string) => any <: (any) => any
  assert not((string) => any <: (unknown) => any)
  assert {} <: {}
  assert {} <: any
  assert {} <: unknown
  assert {x: string} <: {}
  assert {x: string} <: {x: string}
  assert {x: ''} <: {x: string}
end

interface Duck {
  fly: () => void,
  quack: () => void,
}

interface Bird {
  fly: () => void,
}

unittest "a duck is a bird" do
  assert Duck <: Bird
  assert not(Bird <: Duck)
end
