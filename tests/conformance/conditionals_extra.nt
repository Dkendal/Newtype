// Conformance edge cases added by the 2026-06-30 audit (conditionals).
// Every assertion below agrees with tsgo --strict.

type BoolDist(T) as if T <: true then 1 else 2 end

unittest "boolean distributes into true and false branches" do
  assert BoolDist(true) == 1
  assert BoolDist(false) == 2
end

type IsNeverD(T) as if T <: never then true else false end
type ToArr(T) as if T <: any then T[] else never end

unittest "never as naked input short-circuits to never" do
  assert IsNeverD(never) == never
  assert IsNeverD(string) == false
  assert ToArr(never) == never
  assert ToArr(any) == any[]
end

type IsStr(T) as if T <: string then 1 else 2 end

unittest "unknown does not distribute" do
  assert IsStr(unknown) == 2
end

type ElemElem(T) as if T <: Array(Array(?U)) then U else never end
type RetArr(T) as if T <: () => Array(?U) then U else never end
type RetOf(T) as if T <: (any) => ?R then R else never end
type UnwrapArr(T) as if T <: Promise(Array(?U)) then U else never end

unittest "nested array and function-return infer" do
  assert ElemElem(number[][]) == number
  assert ElemElem(string[]) == never
  assert RetArr(() => string[]) == string
  assert RetOf((any) => number) == number
  assert UnwrapArr(Promise(number[])) == number
  assert UnwrapArr(Promise(string)) == never
end

type Kind(T) as if T <: string then 's' else if T <: number then 'n' else 'o' end end
type Label(T) as if T <: 1 then 'one' else if T <: 2 then 'two' else 'x' end end

unittest "chained conditional classification distributes per member" do
  assert Kind(string) == 's'
  assert Kind(number) == 'n'
  assert Kind(boolean) == 'o'
  assert Kind(string | number) == 's' | 'n'
  assert Label(1 | 2 | 3) == 'one' | 'two' | 'x'
end

type OnlyStr(T) as if T <: string then T else never end

unittest "distributive filter keeps matching union members" do
  assert OnlyStr(string | number) == string
  assert OnlyStr('a' | 'b' | number) == 'a' | 'b'
  assert OnlyStr(number) == never
end

type NN(T) as if T <: null then never else T end
type Always(T) as if T <: string then never else never end

unittest "distribute null member and both-never branches" do
  assert NN(string | null) == string
  assert NN(null) == never
  assert Always(string) == never
  assert Always(number) == never
end

type Both(T) as if T <: (?U) => ?U then U else never end

unittest "infer same var in contravariant and covariant positions" do
  assert Both((string) => string) == string
end

type HasA(T) as if 'a' <: keyof T then 1 else 2 end
type Get(T) as if T <: {x: ?V} then V else never end

unittest "keyof in condition and object property infer" do
  assert HasA({a: number, b: string}) == 1
  assert HasA({b: string}) == 2
  assert Get({x: number}) == number
  assert Get({y: number}) == never
end

type Boxed(T) as if T <: any then {v: T} else never end

unittest "distribute conditional result into object wrapper" do
  assert Boxed(string | number) == {v: string} | {v: number}
end

type Only(T) as if T <: [?A] then A else never end

unittest "single element tuple infer requires exact arity" do
  assert Only([number]) == number
  assert Only([number, string]) == never
end
